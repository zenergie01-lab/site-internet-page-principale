# Variables d'environnement pour Vercel
# Copier ce fichier en .env.local et remplir avec vos vraies URLs

# URL du webhook N8N pour le formulaire de contact
# Format: https://n8n.srv999617.hstgr.cloud/webhook/TESTASSO
N8N_WEBHOOK_URL=https://n8n.srv999617.hstgr.cloud/webhook/TESTASSO

# URL du webhook N8N pour le chat Spirit
# Format: https://n8n.srv999617.hstgr.cloud/webhook/fb5cd438-811e-446c-8551-6004c63c69bf
N8N_CHAT_WEBHOOK_URL=https://n8n.srv999617.hstgr.cloud/webhook/fb5cd438-811e-446c-8551-6004c63c69bf

# Origines autorisées (CORS)
# En production, remplacez par votre domaine réel
# Exemples: https://paroisse-saintemarie.fr,https://www.paroisse-saintemarie.fr
ALLOWED_ORIGIN=https://votre-domaine.com
